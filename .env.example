# Copy to .env.local for local development.
# Add matching variables in Vercel Project Settings > Environment Variables.

# Resend API key (required in production)
# RESEND_API_KEY=

# Verified sender in Resend, e.g. "THE SILENCE <noreply@example.com>" (required in production)
# ACCESS_FROM_EMAIL=

# HMAC secret for signing access cookies (required in production)
# ACCESS_COOKIE_SECRET=

# Shared preview password for unpublished pages
# ACCESS_PASSWORD=

# Client distribution preview protection
# Set to true only on the dedicated preview/staging deployment
# CLIENT_PREVIEW_ENABLED=false
# CLIENT_PREVIEW_USERNAME=
# CLIENT_PREVIEW_PASSWORD=

# Receiving notification recipient(s), comma-separated
# ACCESS_RECEIVING_EMAIL=
# (fallback for typo compatibility)
# ACCESS_RECIVING_EMAIL=

# Optional: admin notification recipient
# ACCESS_ADMIN_EMAIL=

# Resend inbound webhook signing secret
# RESEND_WEBHOOK_SECRET=

# Google Sheets integration for inbound emails
# GOOGLE_SHEETS_SPREADSHEET_ID=
# GOOGLE_SERVICE_ACCOUNT_EMAIL=
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
