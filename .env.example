# Copy to .env.local for local development.
# Add matching variables in Vercel Project Settings > Environment Variables.

# Resend API key (required in production)
# RESEND_API_KEY=

# Verified sender in Resend, e.g. "THE SILENCE <noreply@example.com>" (required in production)
# ACCESS_FROM_EMAIL=

# HMAC secret for signing access cookies (required in production)
# ACCESS_COOKIE_SECRET=

# Optional: admin notification recipient
# ACCESS_ADMIN_EMAIL=
